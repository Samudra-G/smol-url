{
  "AppSettings": {
    "BaseUrl": "https://localhost:7158/api/urls",
    "AllowedCallbackUrls": [
      "http://localhost:3000/auth/google/callback",
      "https://localhost:7158/auth/google/callback",
      "https://oauth.pstmn.io/v1/callback" 
    ]
  },
  "Jwt": {
    "Issuer": "UrlShortener",
    "Audience": "UrlShortener",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Authentication": {
    "Google": {
      "ClientId": "",
      "ClientSecret": ""
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=127.0.0.1;Port=5432;Database=urlshortener;Username=postgres",
    "Redis": "127.0.0.1:6380"
  },
  "RateLimiting": {
    "RedirectPermitLimit": 100,
    "RedirectWindowSeconds": 10,
    "RedirectSegments": 5,
    "RedirectQueueLimit": 20,
    "ShortenConcurrencyLimit": 10,
    "ShortenQueueLimit": 5
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*"
}
